# Supabase PostgreSQL Configuration
# Found in Supabase Dashboard -> Database -> Connection String -> URI
# NOTE: For Alembic migrations, use the direct connection (port 5432) instead of the transaction pooler (port 6543) because DDL statements require session persistence.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase Auth Configuration
# Found in Supabase Dashboard -> Project Settings -> API
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_JWT_SECRET="your-jwt-secret"

# Application Settings
FRONTEND_URL="https://your-frontend-url.com"
COOKIE_DOMAIN=".your-domain.com"
COOKIE_SECURE=true
ENV=production

# Security & Monitoring
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
CSRF_SECRET_KEY="generate-a-strong-random-key"
CSRF_ENABLED=true
SENTRY_DSN="your-sentry-dsn"

# Email (Resend)
RESEND_API_KEY=your-resend-api-key
SENDER_EMAIL=noreply@yourdomain.com

# Token Expiry Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_TOKEN_SECRET=your-email-token-secret
